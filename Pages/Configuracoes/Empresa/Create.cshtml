@page
@model GVC.Web.Pages.Configuracoes.Empresa.CreateModel
@{
    ViewData["Title"] = "Nova empresa";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Nova empresa</h1>
        <p class="text-secondary mb-0">Cadastre uma nova empresa para utilização no ERP.</p>
    </div>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<form method="post" enctype="multipart/form-data" class="card">
    <div class="card-body row g-3">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="col-md-8">
            <label asp-for="Item.RazaoSocial" class="form-label">Razão social</label>
            <input asp-for="Item.RazaoSocial" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.NomeFantasia" class="form-label">Nome fantasia</label>
            <input asp-for="Item.NomeFantasia" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.Cnpj" class="form-label">CNPJ</label>
            <input asp-for="Item.Cnpj" class="form-control" inputmode="numeric" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.InscricaoEstadual" class="form-label">Inscrição estadual</label>
            <input asp-for="Item.InscricaoEstadual" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.InscricaoMunicipal" class="form-label">Inscrição municipal</label>
            <input asp-for="Item.InscricaoMunicipal" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.Cnae" class="form-label">CNAE</label>
            <input asp-for="Item.Cnae" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.AmbienteSefaz" class="form-label">Ambiente SEFAZ</label>
            <select asp-for="Item.AmbienteSefaz" class="form-select">
                <option value="1">Produção</option>
                <option value="2">Homologação</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Item.RegimeTributario" class="form-label">Regime tributário</label>
            <select asp-for="Item.RegimeTributario" class="form-select">
                <option value="1">Simples Nacional</option>
                <option value="2">Simples - excesso</option>
                <option value="3">Regime normal</option>
            </select>
        </div>
        <div class="col-md-8">
            <label asp-for="Item.CertificadoDigital" class="form-label">Certificado digital (caminho)</label>
            <input asp-for="Item.CertificadoDigital" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.CertificadoSenha" class="form-label">Senha do certificado</label>
            <input asp-for="Item.CertificadoSenha" type="password" class="form-control" />
        </div>

        <div class="col-12"><hr class="my-1" /></div>

        <div class="col-md-3">
            <label asp-for="Item.Cep" class="form-label">CEP</label>
            <input asp-for="Item.Cep" class="form-control" inputmode="numeric" />
        </div>
        <div class="col-md-7">
            <label asp-for="Item.Logradouro" class="form-label">Logradouro</label>
            <input asp-for="Item.Logradouro" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Item.Numero" class="form-label">Número</label>
            <input asp-for="Item.Numero" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.Bairro" class="form-label">Bairro</label>
            <input asp-for="Item.Bairro" class="form-control" />
        </div>
        <div class="col-md-8">
            <label class="form-label">Cidade</label>
            <div class="position-relative">
                <input class="form-control" data-city-search data-city-target="Item_CidadeId" placeholder="Digite o nome da cidade" autocomplete="off" />
                <input asp-for="Item.CidadeId" type="hidden" />
                <div data-city-results class="list-group position-absolute w-100 shadow" style="z-index:1050"></div>
            </div>
            <span asp-validation-for="Item.CidadeId" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Item.Telefone" class="form-label">Telefone</label>
            <input asp-for="Item.Telefone" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.Email" class="form-label">E-mail</label>
            <input asp-for="Item.Email" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Item.Site" class="form-label">Site</label>
            <input asp-for="Item.Site" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Item.Responsavel" class="form-label">Responsável</label>
            <input asp-for="Item.Responsavel" class="form-control" />
        </div>

        <div class="col-12"><hr class="my-1" /></div>

        <div class="col-md-6">
            <label asp-for="LogoArquivo" class="form-label">Logo da empresa</label>
            <input asp-for="LogoArquivo" type="file" accept="image/jpeg,image/png,image/webp" class="form-control" data-image-input data-image-preview="logoPreview" />
            <div class="form-text">JPG, PNG ou WEBP, com no máximo 5 MB.</div>
            <span asp-validation-for="LogoArquivo" class="text-danger"></span>
            <img id="logoPreview" class="img-thumbnail mt-2 d-none" style="max-height:160px;max-width:100%" alt="Pré-visualização da logo" />
        </div>
        <div class="col-md-6">
            <label asp-for="FundoTelaArquivo" class="form-label">Imagem de fundo da tela</label>
            <input asp-for="FundoTelaArquivo" type="file" accept="image/jpeg,image/png,image/webp" class="form-control" data-image-input data-image-preview="fundoPreview" />
            <div class="form-text">JPG, PNG ou WEBP, com no máximo 10 MB.</div>
            <span asp-validation-for="FundoTelaArquivo" class="text-danger"></span>
            <img id="fundoPreview" class="img-thumbnail mt-2 d-none" style="max-height:160px;max-width:100%" alt="Pré-visualização da imagem de fundo" />
        </div>
    </div>

    <div class="card-footer d-flex justify-content-end gap-2">
        <a asp-page="Index" class="btn btn-light">Cancelar</a>
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-lg"></i> Cadastrar empresa
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.gvcCitySearch?.();
        window.gvcImagePreview?.();
    </script>
}
