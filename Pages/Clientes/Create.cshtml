@page
@model GVC.Web.Pages.Clientes.CreateModel
@{ ViewData["Title"] = "Novo cliente"; }
<h1>
    Novo cliente
</h1>
<form method="post" class="card shadow-sm">
    <div class="card-body row g-3">
        <div asp-validation-summary="All" class="text-danger">
        </div>
        <div class="col-md-3">
            <label asp-for="Cliente.TipoCliente" class="form-label">
                Tipo
            </label>
            <select asp-for="Cliente.TipoCliente" class="form-select" id="tipoPessoa">
                <option value="PF">
                    Pessoa física
                </option>
                <option value="PJ">
                    Pessoa jurídica
                </option>
            </select>
        </div>
        <div class="col-md-9">
            <label asp-for="Cliente.Nome" class="form-label">
                Nome / Razão social
            </label>
            <input asp-for="Cliente.Nome" class="form-control">
        </div>
        <div class="col-md-4 pf-field">
            <label asp-for="Cliente.Cpf" class="form-label">
                CPF
            </label>
            <input asp-for="Cliente.Cpf" class="form-control document-mask" data-mask="cpf" inputmode="numeric">
        </div>
        <div class="col-md-4 pf-field">
            <label asp-for="Cliente.Rg" class="form-label">
                RG
            </label>
            <input asp-for="Cliente.Rg" class="form-control">
        </div>
        <div class="col-md-4 pf-field">
            <label asp-for="Cliente.OrgaoExpedidorRg" class="form-label">
                Órgão expedidor
            </label>
            <input asp-for="Cliente.OrgaoExpedidorRg" class="form-control">
        </div>
        <div class="col-md-4 pf-field">
            <label asp-for="Cliente.DataNascimento" class="form-label">
                Nascimento
            </label>
            <input asp-for="Cliente.DataNascimento" type="date" class="form-control">
        </div>
        <div class="col-md-4 pj-field">
            <label asp-for="Cliente.Cnpj" class="form-label">
                CNPJ
            </label>
            <input asp-for="Cliente.Cnpj" class="form-control document-mask" data-mask="cnpj" inputmode="numeric">
        </div>
        <div class="col-md-4 pj-field">
            <label asp-for="Cliente.Ie" class="form-label">
                Inscrição estadual
            </label>
            <input asp-for="Cliente.Ie" class="form-control">
        </div>
        <div class="col-md-4">
            <label asp-for="Cliente.Telefone" class="form-label">
                Telefone
            </label>
            <input asp-for="Cliente.Telefone" class="form-control">
        </div>
        <div class="col-md-8">
            <label asp-for="Cliente.Email" class="form-label">
                E-mail
            </label>
            <input asp-for="Cliente.Email" class="form-control">
        </div>
        <div class="col-md-3">
            <label for="Cep" class="form-label">
                CEP
            </label>
            <input asp-for="Cliente.Cep" id="Cep" class="form-control" inputmode="numeric" autocomplete="postal-code" data-cep-autocomplete>
        </div>
        <div class="col-md-7">
            <label for="Logradouro" class="form-label">
                Logradouro
            </label>
            <input asp-for="Cliente.Logradouro" id="Logradouro" class="form-control" autocomplete="address-line1" data-cep-logradouro>
        </div>
        <div class="col-md-2">
            <label for="Numero" class="form-label">
                Número
            </label>
            <input asp-for="Cliente.Numero" id="Numero" class="form-control" autocomplete="address-line2" data-cep-numero>
        </div>
        <div class="col-md-4">
            <label for="Bairro" class="form-label">
                Bairro
            </label>
            <input asp-for="Cliente.Bairro" id="Bairro" class="form-control" data-cep-bairro>
        </div>
        <div class="col-md-5">
            <label class="form-label">
                Cidade
            </label>
            <div class="position-relative">
                <input id="CidadeNome" class="form-control" data-city-search data-city-target="CidadeID" placeholder="Digite o nome da cidade" autocomplete="off">
                <input asp-for="Cliente.CidadeId" id="CidadeID" type="hidden" data-cep-cidade-id>
                <div data-city-results class="list-group position-absolute w-100 shadow" style="z-index:1050">
                </div>
            </div>
            <span asp-validation-for="Cliente.CidadeId" class="text-danger">
            </span>
        </div>
        <div class="col-md-3">
            <label asp-for="Cliente.LimiteCredito" class="form-label">
                Limite de crédito
            </label>
            <input asp-for="Cliente.LimiteCredito" class="form-control">
        </div>
        <div class="col-md-3">
            <label asp-for="Cliente.Status" class="form-label">
                Status
            </label>
            <select asp-for="Cliente.Status" class="form-select">
                <option value="1">
                    Ativo
                </option>
                <option value="0">
                    Inativo
                </option>
            </select>
        </div>
        <div class="col-12">
            <label asp-for="Cliente.Observacoes" class="form-label">
                Observações
            </label>
            <textarea asp-for="Cliente.Observacoes" class="form-control" rows="3">
            </textarea>
        </div>
    </div>
    <div class="card-footer text-end">
        <a asp-page="Index" class="btn btn-light">
            Cancelar
        </a>
        <button class="btn btn-primary">
            Salvar cliente
        </button>
    </div>
</form>
@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    window.gvcClienteForm?.();window.gvcCitySearch?.();
</script>
}
