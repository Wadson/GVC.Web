@page
@model GVC.Web.Pages.Account.LoginModel
@{Layout=null;}
<!doctype html>
<html lang="pt-br">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width">
        <title>
            Entrar - GVC ERP
        </title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="~/css/site.css">
    </head>
    <body class="login-page">
        <main class="card shadow login-card">
            <div class="card-body p-4 p-md-5 text-center">
                <div style="height:110px" class="d-flex align-items-center justify-content-center mb-2">
                    <img id="empresaLogo" class="img-fluid d-none" style="max-height:105px;max-width:240px" alt="Logo da empresa">
                    <h1 id="logoFallback" class="h3">
                        GVC ERP
                    </h1>
                </div>
                <p class="text-secondary mb-4">
                    Entre para continuar
                </p>
                @if(TempData["Message"] is string message){
                <div class="alert alert-success">
                    @message
                </div>
                }
                <form method="post" class="text-start">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger">
                    </div>
                    <input type="hidden" asp-for="ReturnUrl">
                    <div class="mb-3">
                        <label asp-for="Input.EmpresaId" class="form-label">
                        </label>
                        <select asp-for="Input.EmpresaId" class="form-select" id="empresaLogin">
                            <option value="0">
                                Selecione a empresa...
                            </option>
                            @foreach(var empresa in Model.Empresas){
                            <option value="@empresa.Id" data-logo="@Url.Page("Login","LogoEmpresa",new{empresaId=empresa.Id})">
                                @empresa.Nome
                            </option>
                            }
                        </select>
                        <span asp-validation-for="Input.EmpresaId" class="text-danger">
                        </span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">
                        </label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username">
                        <span asp-validation-for="Input.Email" class="text-danger">
                        </span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Senha" class="form-label">
                        </label>
                        <div class="input-group">
                            <input asp-for="Input.Senha" class="form-control" autocomplete="current-password" id="senhaLogin">
                            <button class="btn btn-outline-secondary" type="button" id="alternarSenha" aria-label="Visualizar senha" title="Visualizar senha" aria-pressed="false">
                                <svg id="iconeVisualizarSenha" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/>
                                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M6.5 8a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0"/>
                                </svg>
                                <svg id="iconeOcultarSenha" class="d-none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755q-.27.27-.57.517z"/>
                                    <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.144 2.144.823.823A7 7 0 0 1 8 13.5c-5 0-8-5.5-8-5.5s.936-1.712 2.632-3.23l.708.708a13 13 0 0 0-2.168 2.521 13 13 0 0 0 1.66 2.043C4.12 11.332 5.88 12.5 8 12.5q.607 0 1.153-.18"/>
                                    <path d="M3.35 1.646a.5.5 0 1 0-.708.708l10 10a.5.5 0 0 0 .708-.708z"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Senha" class="text-danger">
                        </span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="Input.Lembrar" class="form-check-input">
                        <label asp-for="Input.Lembrar" class="form-check-label">
                        </label>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">
                        Entrar
                    </button>
                    <a asp-page="ForgotPassword" class="d-block text-center mt-3">
                        Esqueci minha senha
                    </a>
                </form>
            </div>
        </main>
        <partial name="_ValidationScriptsPartial"/>
        <script>
            const select=document.getElementById('empresaLogin'),logo=document.getElementById('empresaLogo'),fallback=document.getElementById('logoFallback');function updateLogo(){const url=select.selectedOptions[0]?.dataset.logo;if(!url){logo.classList.add('d-none');fallback.classList.remove('d-none');return}logo.onload=()=>{logo.classList.remove('d-none');fallback.classList.add('d-none')};logo.onerror=()=>{logo.classList.add('d-none');fallback.classList.remove('d-none')};logo.src=url}select.addEventListener('change',updateLogo);updateLogo();

            const senha=document.getElementById('senhaLogin'),alternarSenha=document.getElementById('alternarSenha'),iconeVisualizar=document.getElementById('iconeVisualizarSenha'),iconeOcultar=document.getElementById('iconeOcultarSenha');alternarSenha.addEventListener('click',()=>{const visivel=senha.type==='password';senha.type=visivel?'text':'password';iconeVisualizar.classList.toggle('d-none',visivel);iconeOcultar.classList.toggle('d-none',!visivel);const descricao=visivel?'Ocultar senha':'Visualizar senha';alternarSenha.setAttribute('aria-label',descricao);alternarSenha.setAttribute('title',descricao);alternarSenha.setAttribute('aria-pressed',String(visivel));senha.focus()});
        </script>
    </body>
</html>
