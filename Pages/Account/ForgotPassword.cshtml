@page
@model GVC.Web.Pages.Account.ForgotPasswordModel
@{Layout=null;}
<!doctype html>
<html lang="pt-br">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width">
        <title>
            Recuperar senha
        </title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="~/css/site.css">
    </head>
    <body class="login-page">
        <main class="card login-card">
            <div class="card-body p-4">
                <h1 class="h4">
                    Recuperar senha
                </h1>
                <p class="text-secondary">
                    Informe seu e-mail. Se ele estiver cadastrado, enviaremos as instruções.
                </p>
                @if(TempData["ResetError"] is string error){
                <div class="alert alert-warning">
                    @error
                </div>
                }
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger">
                    </div>
                    <label asp-for="Email" class="form-label">
                    </label>
                    <input asp-for="Email" class="form-control" autocomplete="email">
                    <span asp-validation-for="Email" class="text-danger">
                    </span>
                    <button class="btn btn-primary w-100 mt-3">
                        Enviar novo link
                    </button>
                    <a asp-page="Login" class="d-block text-center mt-3">
                        Voltar ao login
                    </a>
                </form>
            </div>
        </main>
        <partial name="_ValidationScriptsPartial"/>
    </body>
</html>
