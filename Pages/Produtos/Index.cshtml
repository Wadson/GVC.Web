@page
@model GVC.Web.Pages.Produtos.IndexModel
@{
    ViewData["Title"] = "Produtos";
}

<section class="products-index">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Produtos</h1>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Novo produto
        </a>
    </div>

    <form id="productSearchForm"
          method="get"
          class="card card-body mb-3"
          data-search-url="@Url.Page("Index", "Pesquisar")">
        <label for="productSearchInput" class="form-label">Pesquisar produtos</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
            <input asp-for="Pesquisa"
                   id="productSearchInput"
                   class="form-control"
                   placeholder="Digite nome, referência, código, EAN, SKU ou atributo..."
                   autocomplete="off"
                   aria-controls="productSearchResults">
            <button id="productSearchSubmit" class="btn btn-primary" type="submit">Pesquisar</button>
            <a id="productSearchClear"
               asp-page="Index"
               class="btn btn-outline-secondary @(string.IsNullOrWhiteSpace(Model.Pesquisa) ? "d-none" : null)">
                Limpar
            </a>
        </div>
        <small class="form-text mt-1">A listagem é atualizada automaticamente enquanto você digita.</small>
    </form>

    <div id="productSearchFeedback" class="visually-hidden" role="status" aria-live="polite"></div>
    <div id="productSearchResults"
         data-auto-expand="@(!string.IsNullOrWhiteSpace(Model.Pesquisa) ? "true" : "false")">
        <partial name="_ListaProdutos" model="Model.Produtos" />
    </div>
</section>

@section Scripts {
    <script src="~/js/product-list.js" asp-append-version="true"></script>
}
