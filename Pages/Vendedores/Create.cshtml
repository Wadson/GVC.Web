@page
@model GVC.Web.Pages.Vendedores.CreateModel
@{ViewData["Title"]="Novo vendedor";}
<h1>
    Novo vendedor
</h1>
<form method="post" class="card">
    <div class="card-body row g-3">
        <div asp-validation-summary="All" class="text-danger">
        </div>
        <div class="col-md-8">
            <label class="form-label">
                Nome
            </label>
            <input asp-for="Item.Nome" class="form-control">
        </div>
        <div class="col-md-4">
            <label class="form-label">
                CPF
            </label>
            <input asp-for="Item.Cpf" class="form-control">
        </div>
        <div class="col-md-4">
            <label class="form-label">
                RG
            </label>
            <input asp-for="Item.Rg" class="form-control">
        </div>
        <div class="col-md-4">
            <label class="form-label">
                Telefone
            </label>
            <input asp-for="Item.Telefone" class="form-control">
        </div>
        <div class="col-md-4">
            <label class="form-label">
                E-mail
            </label>
            <input asp-for="Item.Email" class="form-control">
        </div>
        <div class="col-md-3">
            <label class="form-label">
                Nascimento
            </label>
            <input asp-for="Item.DataNascimento" type="date" class="form-control">
        </div>
        <div class="col-md-3">
            <label class="form-label">
                Contratação
            </label>
            <input asp-for="Item.DataContratacao" type="date" class="form-control">
        </div>
        <div class="col-md-3">
            <label class="form-label">
                Comissão %
            </label>
            <input asp-for="Item.Comissao" class="form-control">
        </div>
        <div class="col-md-3">
            <label class="form-label">
                Status
            </label>
            <select asp-for="Item.Status" class="form-select">
                <option value="1">
                    Ativo
                </option>
                <option value="0">
                    Inativo
                </option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">
                CEP
            </label>
            <input asp-for="Item.Cep" class="form-control">
        </div>
        <div class="col-md-7">
            <label class="form-label">
                Endereço
            </label>
            <input asp-for="Item.Endereco" class="form-control">
        </div>
        <div class="col-md-2">
            <label class="form-label">
                Número
            </label>
            <input asp-for="Item.Numero" class="form-control">
        </div>
        <div class="col-md-4">
            <label class="form-label">
                Bairro
            </label>
            <input asp-for="Item.Bairro" class="form-control">
        </div>
        <div class="col-md-8">
            <label class="form-label">
                Cidade
            </label>
            <div class="position-relative">
                <input class="form-control" data-city-search data-city-target="Item_CidadeId" placeholder="Digite o nome da cidade">
                <input asp-for="Item.CidadeId" type="hidden">
                <div data-city-results class="list-group position-absolute w-100 shadow" style="z-index:1050">
                </div>
            </div>
        </div>
        <div class="col-12">
            <label class="form-label">
                Observações
            </label>
            <textarea asp-for="Item.Observacoes" class="form-control">
            </textarea>
        </div>
    </div>
    <div class="card-footer text-end">
        <a asp-page="Index" class="btn btn-light">
            Cancelar
        </a>
        <button class="btn btn-primary">
            Salvar
        </button>
    </div>
</form>
@section Scripts{
<partial name="_ValidationScriptsPartial"/>
<script>
    window.gvcCitySearch?.();
</script>
}
