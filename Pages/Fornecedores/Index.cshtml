@page
@model GVC.Web.Pages.Fornecedores.IndexModel
@{ViewData["Title"]="Fornecedores";}
<div class="d-flex justify-content-between mb-3">
    <h1>
        Fornecedores
    </h1>
    <a asp-page="Create" class="btn btn-primary">
        Novo fornecedor
    </a>
</div>
<form method="get" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-9 col-lg-10">
            <label asp-for="Busca" class="form-label">Pesquisar fornecedor</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                <input asp-for="Busca" class="form-control" placeholder="Nome, CNPJ ou e-mail" autocomplete="off">
            </div>
        </div>
        <div class="col-md-3 col-lg-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">Pesquisar</button>
            @if (!string.IsNullOrWhiteSpace(Model.Busca))
            {
                <a asp-page="Index" class="btn btn-outline-secondary" title="Limpar pesquisa" aria-label="Limpar pesquisa">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
        </div>
    </div>
</form>
<div class="card table-responsive">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>
                    Nome
                </th>
                <th>
                    CNPJ
                </th>
                <th>
                    Telefone
                </th>
                <th>
                    E-mail
                </th>
                <th class="text-end">
                    Ações
                </th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Itens.Count == 0)
            {
            <tr>
                <td colspan="5" class="text-center text-secondary py-4">
                    Nenhum fornecedor encontrado.
                </td>
            </tr>
            }
            @foreach(var x in Model.Itens){
            <tr>
                <td>
                    @x.Nome
                </td>
                <td>
                    @x.Cnpj
                </td>
                <td>
                    @x.Telefone
                </td>
                <td>
                    @x.Email
                </td>
                <td class="text-end">
                    <a asp-page="Edit" asp-route-id="@x.FornecedorId" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil" aria-hidden="true"></i> Editar
                    </a>
                    <form method="post" asp-page-handler="Excluir" asp-route-id="@x.FornecedorId" class="d-inline" onsubmit="return confirm('Excluir este fornecedor?')">
                        <button class="btn btn-sm btn-outline-danger">
                            Excluir
                        </button>
                    </form>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>
