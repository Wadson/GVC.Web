@page
@model GVC.Web.Pages.Financeiro.Recebiveis.ReceberModel
@{ViewData["Title"]="Receber conta";}
<h1>
    Receber conta
</h1>
<div class="card card-body mb-3">
    <div class="row">
        <div class="col-md-4">
            <small class="text-secondary">
                Cliente
            </small>
            <div class="fw-semibold">
                @Model.Parcela.Venda.Cliente.Nome
            </div>
        </div>
        <div class="col-md-2">
            <small class="text-secondary">
                Venda / Parcela
            </small>
            <div>
                #@Model.Parcela.VendaId / @Model.Parcela.NumeroParcela
            </div>
        </div>
        <div class="col-md-2">
            <small class="text-secondary">
                Vencimento
            </small>
            <div>
                @Model.Parcela.DataVencimento.ToString("dd/MM/yyyy")
            </div>
        </div>
        <div class="col-md-2">
            <small class="text-secondary">
                Valor original
            </small>
            <div>
                @Model.Parcela.ValorParcela.ToString("C")
            </div>
        </div>
        <div class="col-md-2">
            <small class="text-secondary">
                Saldo
            </small>
            <div class="fw-bold text-primary">
                @Model.Saldo.ToString("C")
            </div>
        </div>
    </div>
</div>
<form method="post" class="card">
    <input asp-for="Input.ParcelaId" type="hidden">
    <div class="card-body row g-3">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger">
        </div>
        <div class="col-md-4">
            <label asp-for="Input.Valor" class="form-label">
            </label>
            <input asp-for="Input.Valor" class="form-control" inputmode="decimal">
            <span asp-validation-for="Input.Valor" class="text-danger">
            </span>
            <small class="text-secondary">
                Para pagamento parcial, informe um valor menor que o saldo.
            </small>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.DataPagamento" class="form-label">
            </label>
            <input asp-for="Input.DataPagamento" type="date" class="form-control">
            <span asp-validation-for="Input.DataPagamento" class="text-danger">
            </span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.FormaPagamentoId" class="form-label">
            </label>
            <select asp-for="Input.FormaPagamentoId" asp-items="Model.FormasPagamento" class="form-select">
                <option value="0">
                    Selecione...
                </option>
            </select>
            <span asp-validation-for="Input.FormaPagamentoId" class="text-danger">
            </span>
        </div>
        <div class="col-12">
            <label asp-for="Input.Observacao" class="form-label">
            </label>
            <textarea asp-for="Input.Observacao" class="form-control" rows="3">
            </textarea>
        </div>
    </div>
    <div class="card-footer text-end">
        <a asp-page="Index" class="btn btn-light">
            Cancelar
        </a>
        <button class="btn btn-success">
            Confirmar recebimento
        </button>
    </div>
</form>
@section Scripts{
<partial name="_ValidationScriptsPartial"/>
}
