@page
@model GVC.Web.Pages.Estoque.AjusteManualModel
@{ViewData["Title"]="Ajuste de estoque";}
<h1>
    Ajuste de estoque
</h1>
<form method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger">
        </div>
        <label asp-for="Alvo" class="form-label">Produto / SKU</label>
        <select asp-for="Alvo" asp-items="Model.Opcoes" class="form-select mb-1">
            <option value="">Selecione...</option>
        </select>
        <span asp-validation-for="Alvo" class="text-danger d-block mb-3"></span>
        <label asp-for="NovoEstoque" class="form-label">
        </label>
        <input asp-for="NovoEstoque" class="form-control mb-3">
        <label asp-for="Observacao" class="form-label">
        </label>
        <textarea asp-for="Observacao" class="form-control">
        </textarea>
    </div>
    <div class="card-footer">
        <button class="btn btn-primary">
            Aplicar ajuste
        </button>
    </div>
</form>
