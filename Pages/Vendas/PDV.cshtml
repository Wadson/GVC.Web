@page
@model GVC.Web.Pages.Vendas.PDVModel
@{ViewData["Title"]="PDV";}
<div id="pdvApp" class="pdv-app" data-product-url="@Url.Page("PDV","BuscarProdutos")" data-client-url="@Url.Page("PDV","BuscarClientes")" data-seller-url="@Url.Page("PDV","BuscarVendedores")" data-finish-url="@Url.Page("PDV","Finalizar")">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-0">
                Pedido de Venda / PDV
            </h1>
            <small class="text-secondary">
                Selecione cliente, vendedor e produtos
            </small>
        </div>
        <div id="totalGeral" class="pdv-totalizer text-end" role="button" tabindex="0" title="Enter para fechar a venda">
            <small>Total da venda</small>
            <strong>R$ 0,00</strong>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body position-relative">
                    <label class="form-label">
                        Pesquisar produto por nome, referência, código ou EAN
                    </label>
                    <span class="pdv-field-shortcut float-end">F1 / F2</span>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                        <input id="buscaProduto" class="form-control" placeholder="Digite ou leia o código de barras..." autocomplete="off">
                    </div>
                    <div id="resultadosProduto" class="list-group pdv-autocomplete position-absolute start-0 end-0 mx-3 shadow" style="z-index:1050">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>
                                    Produto
                                </th>
                                <th width="120">
                                    Qtd.
                                </th>
                                <th class="text-end">
                                    Unitário
                                </th>
                                <th width="120">
                                    Desconto
                                </th>
                                <th class="text-end">
                                    Total
                                </th>
                                <th>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="itensVenda">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="position-relative mb-3">
                        <label class="form-label">
                            Cliente
                        </label>
                        <span class="pdv-field-shortcut position-absolute end-0 top-0">F3</span>
                        <input id="buscaCliente" class="form-control" placeholder="Nome ou código" autocomplete="off">
                        <input id="clienteId" type="hidden">
                        <div id="resultadosCliente" class="list-group pdv-autocomplete position-absolute w-100 shadow" style="z-index:1040">
                        </div>
                    </div>
                    <div class="position-relative mb-3">
                        <label class="form-label">
                            Vendedor
                        </label>
                        <span class="pdv-field-shortcut position-absolute end-0 top-0">F4</span>
                        <input id="buscaVendedor" class="form-control" placeholder="Nome ou código" autocomplete="off">
                        <input id="vendedorId" type="hidden">
                        <div id="resultadosVendedor" class="list-group pdv-autocomplete position-absolute w-100 shadow" style="z-index:1030">
                        </div>
                    </div>
                    <label class="form-label">
                        Desconto geral
                    </label>
                    <span class="pdv-field-shortcut float-end">F7</span>
                    <input id="descontoGeral" inputmode="decimal" value="0,00" class="form-control">
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span>
                            Subtotal
                        </span>
                        <strong id="subtotal">
                            R$ 0,00
                        </strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>
                            Descontos
                        </span>
                        <strong id="descontos">
                            R$ 0,00
                        </strong>
                    </div>
                </div>
                <div class="card-footer">
                    <button id="abrirPagamento" type="button" class="btn btn-success btn-lg w-100" disabled>
                        <i class="bi bi-check2-circle me-1"></i> Fechar venda <span class="opacity-75">(F10)</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="pagamentoModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5">
                        Fechamento da venda
                    </h2>
                    <button class="btn-close" data-bs-dismiss="modal">
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">
                                Forma de pagamento
                            </label>
                            <select id="formaPagamentoId" class="form-select">
                                <option value="">
                                    Selecione...
                                </option>
                                @foreach(var forma in Model.FormasPagamento){
                                <option value="@forma.FormaPagamentoId">
                                    @forma.Descricao
                                </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">
                                Quantidade de parcelas
                            </label>
                            <input id="quantidadeParcelas" type="number" min="1" max="60" value="1" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">
                                Intervalo (dias)
                            </label>
                            <input id="intervaloParcelas" type="number" min="1" max="365" value="30" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">
                                Primeiro vencimento
                            </label>
                            <input id="primeiroVencimento" type="date" class="form-control">
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button id="gerarParcelas" type="button" class="btn btn-outline-primary w-100">
                                Gerar parcelas
                            </button>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input id="recebidoAgora" type="checkbox" class="form-check-input">
                                <label for="recebidoAgora" class="form-check-label">
                                    Recebido agora / lançar no caixa
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive mt-3">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>
                                        Parcela
                                    </th>
                                    <th>
                                        Vencimento
                                    </th>
                                    <th class="text-end">
                                        Valor
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="parcelasVenda">
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="2">
                                        Total das parcelas
                                    </th>
                                    <th id="totalParcelas" class="text-end">
                                    </th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div id="pdvError" class="alert alert-danger mt-3 d-none">
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-light" data-bs-dismiss="modal">
                        Voltar
                    </button>
                    <button id="finalizarVenda" class="btn btn-success">
                        Concluir venda
                    </button>
                </div>
            </div>
        </div>
    </div>
    <nav class="pdv-shortcuts" aria-label="Atalhos do PDV">
        <button type="button" data-pdv-shortcut="F2"><kbd>F1/F2</kbd><span>Produto</span></button>
        <button type="button" data-pdv-shortcut="F3"><kbd>F3</kbd><span>Cliente</span></button>
        <button type="button" data-pdv-shortcut="F4"><kbd>F4</kbd><span>Vendedor</span></button>
        <button type="button" data-pdv-shortcut="F7"><kbd>F7</kbd><span>Desconto</span></button>
        <button type="button" data-pdv-shortcut="F8"><kbd>F8</kbd><span>Excluir item</span></button>
        <button type="button" data-pdv-shortcut="F10" class="pdv-shortcut-primary"><kbd>F10</kbd><span>Fechar venda</span></button>
        <button type="button" data-pdv-shortcut="Escape"><kbd>ESC</kbd><span>Voltar/Limpar</span></button>
    </nav>
    @Html.AntiForgeryToken()
</div>
@section Scripts{
<script src="~/js/pdv.js" asp-append-version="true">
</script>
}
