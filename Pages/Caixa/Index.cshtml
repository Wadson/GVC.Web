@page
@model GVC.Web.Pages.Caixa.IndexModel
@{ViewData["Title"]="Caixa";}
<h1>
    Caixa
</h1>
<div asp-validation-summary="ModelOnly" class="text-danger">
</div>
@if(Model.CaixaAtual is null){
<form method="post" asp-page-handler="Abrir" class="card">
    <div class="card-body">
        <h2 class="h5">
            Abrir caixa
        </h2>
        <label asp-for="SaldoInicial" class="form-label">
        </label>
        <input asp-for="SaldoInicial" class="form-control" style="max-width:240px">
    </div>
    <div class="card-footer">
        <button class="btn btn-success">
            Abrir caixa
        </button>
    </div>
</form>
}else{
<div class="card">
    <div class="card-body">
        <p>
            Aberto em
            <strong>
                @Model.CaixaAtual.DataAbertura
            </strong>
        </p>
        <div class="display-5">
            @Model.Saldo.ToString("C")
        </div>
    </div>
    <div class="card-footer">
        <a href="/Caixa/ImprimirFechamento/@Model.CaixaAtual.CaixaId" class="btn btn-outline-primary me-2" target="_blank"><i class="bi bi-printer"></i> Imprimir caixa</a>
        <form method="post" asp-page-handler="Fechar" class="d-flex gap-2">
            <input name="saldoInformado" type="number" step="0.01" class="form-control" placeholder="Saldo contado" required>
            <button class="btn btn-danger">
                Fechar caixa
            </button>
        </form>
    </div>
</div>
}
