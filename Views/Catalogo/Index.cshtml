@model CatalogoVirtualViewModel
@{ Layout = null; ViewData["Title"] = $"Catálogo - {Model.EmpresaNome}"; }
<!doctype html>
<html lang="pt-br"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
<title>@ViewData["Title"]</title><link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
<style>
body{background:#f4f6f8;color:#1d2935}.catalog-header{background:linear-gradient(120deg,#003366,#075b9c);color:#fff}.brand-logo{width:92px;height:92px;object-fit:contain;background:#fff}.product-card{border:0;transition:.2s;overflow:hidden}.product-card:hover{transform:translateY(-4px);box-shadow:0 .8rem 2rem #00336622!important}.product-photo{height:230px;object-fit:cover;background:#eef2f6}.promo-badge{position:absolute;top:12px;left:12px}.filter-link.active{background:#003366;color:#fff}.price{color:#08783e}.sticky-filters{position:sticky;top:1rem}
</style></head><body>
<header class="catalog-header py-4 shadow-sm"><div class="container"><div class="d-flex flex-wrap align-items-center gap-3">
@if (Model.LogoDataUri is not null) { <img src="@Model.LogoDataUri" class="brand-logo rounded-3 p-2" alt="Logo @Model.EmpresaNome" /> }
<div class="flex-grow-1"><h1 class="mb-1">@Model.EmpresaNome</h1><div>@Model.Telefone · @Model.Email</div><small>@Model.Endereco</small></div>
<a href="/Catalogo/ExportarPdf/@Model.EmpresaId@(Model.CategoriaId.HasValue ? $"?categoriaId={Model.CategoriaId}" : "")" class="btn btn-light btn-lg"><span aria-hidden="true">↓</span> Baixar catálogo em PDF</a>
</div><form method="get" class="mt-4"><div class="input-group input-group-lg"><input name="busca" value="@Model.Busca" id="globalSearch" class="form-control" placeholder="Busque produtos por nome ou código" /><input type="hidden" name="categoriaId" value="@Model.CategoriaId" /><input type="hidden" name="marcaId" value="@Model.MarcaId" /><button class="btn btn-warning">Buscar</button></div></form></div></header>
<main class="container py-4"><div class="row g-4"><aside class="col-lg-3"><div class="sticky-filters">
<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-bold">Categorias</div><div class="list-group list-group-flush"><a href="/Catalogo/@Model.EmpresaId" class="list-group-item filter-link @(!Model.CategoriaId.HasValue ? "active" : "")">Todas <span class="badge bg-secondary float-end">@Model.Categorias.Sum(x=>x.Quantidade)</span></a>@foreach(var x in Model.Categorias){<a href="?categoriaId=@x.Id&marcaId=@Model.MarcaId&busca=@Uri.EscapeDataString(Model.Busca??"")" class="list-group-item filter-link @(Model.CategoriaId==x.Id ? "active" : "")">@x.Nome <span class="badge bg-secondary float-end">@x.Quantidade</span></a>}</div></div>
<div class="card border-0 shadow-sm"><div class="card-header bg-white fw-bold">Marcas</div><div class="list-group list-group-flush"><a href="?categoriaId=@Model.CategoriaId&busca=@Uri.EscapeDataString(Model.Busca??"")" class="list-group-item filter-link @(!Model.MarcaId.HasValue ? "active" : "")">Todas</a>@foreach(var x in Model.Marcas){<a href="?categoriaId=@Model.CategoriaId&marcaId=@x.Id&busca=@Uri.EscapeDataString(Model.Busca??"")" class="list-group-item filter-link @(Model.MarcaId==x.Id ? "active" : "")">@x.Nome <span class="badge bg-secondary float-end">@x.Quantidade</span></a>}</div></div>
</div></aside><section class="col-lg-9"><div class="d-flex justify-content-between mb-3"><h2 class="h4">Produtos</h2><span class="text-secondary" id="productCount">@Model.Produtos.Count encontrados</span></div><div class="row g-4" id="productGrid">
@foreach(var produto in Model.Produtos){ var mensagem=Uri.EscapeDataString($"Olá, tenho interesse no produto: {produto.Nome} - {produto.Preco:C}");
<div class="col-sm-6 col-xl-4 product-item" data-search="@(produto.Nome.ToLowerInvariant()) @(produto.Marca.ToLowerInvariant())"><article class="card product-card shadow-sm h-100 position-relative">@if(produto.EmPromocao){<span class="badge text-bg-danger promo-badge">PROMOÇÃO</span>}<img src="@(string.IsNullOrWhiteSpace(produto.Imagem)?"/images/no-product.svg":produto.Imagem)" onerror="this.onerror=null;this.src='/images/no-product.svg'" class="card-img-top product-photo" alt="@produto.Nome" /><div class="card-body d-flex flex-column"><small class="text-secondary">@produto.Marca · @produto.Categoria</small><h3 class="h5 mt-1">@produto.Nome</h3><div class="mt-auto">@if(produto.EmPromocao){<div class="text-secondary text-decoration-line-through">@produto.PrecoOriginal.ToString("C")</div>}<div class="price fs-3 fw-bold">@produto.Preco.ToString("C")</div>@if(!string.IsNullOrWhiteSpace(Model.WhatsApp)){<a href="https://wa.me/@Model.WhatsApp?text=@mensagem" target="_blank" rel="noopener" class="btn btn-success w-100 mt-2">Tenho interesse / WhatsApp</a>}</div></div></article></div>}
</div>@if(Model.Produtos.Count==0){<div class="alert alert-info">Nenhum produto encontrado para os filtros selecionados.</div>}</section></div></main>
<footer class="bg-dark text-white text-center py-3"><small>@Model.RazaoSocial · Catálogo atualizado em @DateTime.Now.ToString("dd/MM/yyyy")</small></footer>
<script>const search=document.getElementById('globalSearch'),items=[...document.querySelectorAll('.product-item')],count=document.getElementById('productCount');search.addEventListener('input',()=>{const term=search.value.trim().toLocaleLowerCase('pt-BR');let visible=0;items.forEach(item=>{item.hidden=term!==''&&!item.dataset.search.includes(term);if(!item.hidden)visible++});count.textContent=`${visible} encontrados`});</script>
</body></html>
