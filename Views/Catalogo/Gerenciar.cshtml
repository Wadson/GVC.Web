@model CatalogoGerenciarViewModel
@{ ViewData["Title"] = "Gerenciar catálogo virtual"; }
<style>
    [data-bs-theme="dark"] .catalog-admin .catalog-card {
        background-color: #111827 !important;
        border: 1px solid #334155 !important;
        color: #e2e8f0;
    }

    [data-bs-theme="dark"] .catalog-admin .catalog-card-header {
        background-color: #0f172a !important;
        border-bottom: 1px solid #334155 !important;
        color: #f8fafc !important;
    }

    [data-bs-theme="dark"] .catalog-admin .catalog-card-header strong {
        color: #f8fafc;
    }

    [data-bs-theme="dark"] .catalog-admin .form-control,
    [data-bs-theme="dark"] .catalog-admin .form-select {
        background-color: #1e293b !important;
        border-color: #475569 !important;
        color: #f8fafc !important;
    }

    [data-bs-theme="dark"] .catalog-admin .form-control::placeholder {
        color: #94a3b8 !important;
        opacity: 1;
    }

    [data-bs-theme="dark"] .catalog-admin .form-control:focus,
    [data-bs-theme="dark"] .catalog-admin .form-select:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 .25rem rgba(59, 130, 246, .25);
    }

    [data-bs-theme="dark"] .catalog-admin .catalog-table {
        --bs-table-bg: #111827;
        --bs-table-color: #e2e8f0;
        --bs-table-border-color: #334155;
        --bs-table-hover-bg: #1e293b;
        --bs-table-hover-color: #fff;
    }

    [data-bs-theme="dark"] .catalog-admin .catalog-table thead th {
        background-color: #0f172a;
        color: #f8fafc;
        border-bottom-color: #475569;
    }
</style>
<div class="catalog-admin">
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4"><div><h1 class="mb-1">Catálogo virtual</h1><p class="text-secondary mb-0">Controle a vitrine pública e gere o PDF dos produtos.</p></div><a href="/Catalogo/@Model.EmpresaId" target="_blank" class="btn btn-outline-primary">Abrir catálogo público</a></div>
<div class="card catalog-card border-0 shadow-sm mb-4"><div class="card-body"><label for="publicLink" class="form-label fw-bold">Link público para clientes</label><div class="input-group"><input id="publicLink" value="@Model.LinkPublico" class="form-control" readonly /><button id="copyLink" type="button" class="btn btn-primary">Copiar link</button></div></div></div>
<div class="card catalog-card border-0 shadow-sm mb-4"><div class="card-header catalog-card-header bg-white py-3"><strong>Gerar catálogo em PDF</strong></div><div class="card-body"><form action="/Catalogo/ExportarPdf/@Model.EmpresaId" method="get" target="_blank" class="row g-3 align-items-end"><div class="col-md-8"><label for="pdfCategory" class="form-label">Produtos</label><select id="pdfCategory" name="categoriaId" class="form-select"><option value="">Todos os produtos visíveis</option>@foreach(var x in Model.Categorias){<option value="@x.Id">@x.Nome (@x.Quantidade)</option>}</select></div><div class="col-md-4"><button class="btn btn-success w-100">Baixar PDF</button></div></form></div></div>
<div class="card catalog-card border-0 shadow-sm"><div class="card-header catalog-card-header bg-white py-3 d-flex justify-content-between"><strong>Produtos do catálogo</strong><input id="manageSearch" type="search" class="form-control form-control-sm" style="max-width:300px" placeholder="Pesquisar produto" /></div><div class="table-responsive"><table class="table catalog-table table-hover align-middle mb-0"><thead><tr><th>Foto</th><th>Produto</th><th>Categoria / Marca</th><th class="text-end">Preço</th><th>Status</th><th class="text-end">Catálogo</th></tr></thead><tbody id="manageProducts">@foreach(var x in Model.Produtos){<tr><td><img src="@(string.IsNullOrWhiteSpace(x.Imagem)?"/images/no-product.svg":x.Imagem)" onerror="this.onerror=null;this.src='/images/no-product.svg'" class="rounded border" style="width:48px;height:48px;object-fit:cover" alt="" /></td><td class="fw-semibold">@x.Nome</td><td>@x.Categoria<br /><small class="text-secondary">@x.Marca</small></td><td class="text-end">@x.Preco.ToString("C")</td><td><span class="badge @(x.Visivel?"text-bg-success":"text-bg-secondary")">@x.Status</span></td><td class="text-end"><form action="/Catalogo/AlternarProduto/@x.ProdutoId" method="post">@Html.AntiForgeryToken()<button class="btn btn-sm @(x.Visivel?"btn-outline-danger":"btn-outline-success")">@(x.Visivel?"Ocultar":"Exibir")</button></form></td></tr>}</tbody></table></div></div>
</div>
@section Scripts{<script>document.getElementById('copyLink').addEventListener('click',async event=>{await navigator.clipboard.writeText(document.getElementById('publicLink').value);event.currentTarget.textContent='Copiado!'});const search=document.getElementById('manageSearch');search.addEventListener('input',()=>document.querySelectorAll('#manageProducts tr').forEach(row=>row.hidden=!row.innerText.toLocaleLowerCase('pt-BR').includes(search.value.trim().toLocaleLowerCase('pt-BR'))));</script>}
