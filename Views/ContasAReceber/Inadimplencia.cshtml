@model RelatorioInadimplenciaViewModel
@{ ViewData["Title"] = "Extrato de clientes e inadimplência"; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h1 class="h3 mb-1">Extrato de clientes e inadimplência</h1><p class="text-secondary mb-0">Parcelas e saldo devedor por cliente.</p></div><button class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer"></i> Imprimir</button></div>
<form method="get" action="/ContasAReceber/RelatorioInadimplencia" class="card shadow-sm border-0 mb-4"><div class="card-body row g-3 align-items-end">
    <div class="col-lg-4"><label asp-for="ClienteId" class="form-label">Cliente</label><select asp-for="ClienteId" class="form-select"><option value="">Todos</option>@foreach (var x in Model.Clientes) { <option value="@x.Id">@x.Descricao</option> }</select></div>
    <div class="col-md-3 col-lg-2"><label asp-for="VencimentoInicial" class="form-label">Vencimento inicial</label><input asp-for="VencimentoInicial" type="date" class="form-control" /></div>
    <div class="col-md-3 col-lg-2"><label asp-for="VencimentoFinal" class="form-label">Vencimento final</label><input asp-for="VencimentoFinal" type="date" class="form-control" /></div>
    <div class="col-md-3 col-lg-2"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select"><option value="">Todos</option><option>Pendente</option><option>Atrasado</option><option>Pago</option></select></div>
    <div class="col-md-3 col-lg-2"><button class="btn btn-primary w-100">Filtrar</button></div>
</div></form>
<div class="row g-3 mb-4"><div class="col-md-4"><div class="card border-danger"><div class="card-body"><small>Total vencido</small><div class="h4 text-danger">@Model.TotalVencido.ToString("C")</div></div></div></div><div class="col-md-4"><div class="card border-warning"><div class="card-body"><small>Total a vencer</small><div class="h4">@Model.TotalAVencer.ToString("C")</div></div></div></div><div class="col-md-4"><div class="card border-primary"><div class="card-body"><small>Saldo devedor</small><div class="h4 text-primary">@Model.SaldoDevedor.ToString("C")</div></div></div></div></div>
@foreach (var cliente in Model.ClientesAgrupados) { <section class="card shadow-sm border-0 mb-3"><div class="card-header d-flex justify-content-between"><strong>@cliente.Cliente <small class="text-secondary">@cliente.Documento</small></strong><span>Saldo: <strong>@cliente.SaldoDevedor.ToString("C")</strong></span></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Venda/Parcela</th><th>Vencimento</th><th>Status</th><th class="text-end">Valor</th><th class="text-end">Recebido</th><th class="text-end">Saldo</th></tr></thead><tbody>@foreach (var p in cliente.Parcelas) { <tr><td>#@p.VendaId / @p.Numero</td><td>@p.Vencimento.ToString("dd/MM/yyyy")</td><td>@p.Status</td><td class="text-end">@p.Valor.ToString("C")</td><td class="text-end">@p.Recebido.ToString("C")</td><td class="text-end">@p.Saldo.ToString("C")</td></tr> }</tbody></table></div></section> }
@if (Model.ClientesAgrupados.Count == 0) { <div class="alert alert-info">Nenhum lançamento encontrado para os filtros informados.</div> }
<style>@@media print { .sidebar,.navbar,form,.btn { display:none!important } main { margin:0!important } .card { box-shadow:none!important; break-inside:avoid } }</style>
