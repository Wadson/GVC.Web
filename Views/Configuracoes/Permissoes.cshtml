@model GerenciarPermissoesViewModel
@{
    ViewData["Title"] = "Permissões do usuário";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Gerenciamento de permissões</h1>
        <p class="text-secondary mb-0">
            Usuário selecionado:
            <strong class="text-dark">@Model.NomeUsuario</strong>
        </p>
    </div>
    <a asp-page="/Usuarios/Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<form asp-controller="Configuracoes" asp-action="SalvarPermissoes" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="UsuarioId" type="hidden" />

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h2 class="h5 mb-0">Permissões por módulo</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Módulo</th>
                        <th scope="col" class="text-center">Visualizar</th>
                        <th scope="col" class="text-center">Criar</th>
                        <th scope="col" class="text-center">Editar</th>
                        <th scope="col" class="text-center">Excluir</th>
                        <th scope="col" class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Permissoes.Count; i++)
                    {
                        <tr data-permission-row>
                            <td class="fw-semibold">
                                @Model.Permissoes[i].Modulo
                                <input asp-for="Permissoes[i].PermissaoId" type="hidden" />
                                <input asp-for="Permissoes[i].UsuarioId" type="hidden" />
                                <input asp-for="Permissoes[i].EmpresaId" type="hidden" />
                                <input asp-for="Permissoes[i].Modulo" type="hidden" />
                            </td>
                            <td class="text-center">
                                <input asp-for="Permissoes[i].PodeVisualizar" class="form-check-input permission-check" />
                            </td>
                            <td class="text-center">
                                <input asp-for="Permissoes[i].PodeCriar" class="form-check-input permission-check" />
                            </td>
                            <td class="text-center">
                                <input asp-for="Permissoes[i].PodeEditar" class="form-check-input permission-check" />
                            </td>
                            <td class="text-center">
                                <input asp-for="Permissoes[i].PodeExcluir" class="form-check-input permission-check" />
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-primary" data-check-row>
                                    Marcar todos
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white d-flex justify-content-end gap-2 py-3">
            <a asp-page="/Usuarios/Index" class="btn btn-light">Voltar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Salvar alterações
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.querySelectorAll('[data-check-row]').forEach(button => {
            button.addEventListener('click', () => {
                const checkboxes = button.closest('[data-permission-row]')
                    .querySelectorAll('.permission-check');
                const marcar = [...checkboxes].some(checkbox => !checkbox.checked);

                checkboxes.forEach(checkbox => checkbox.checked = marcar);
                button.textContent = marcar ? 'Desmarcar todos' : 'Marcar todos';
            });
        });
    </script>
}
