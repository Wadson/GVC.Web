@model IReadOnlyList<GVC.Web.Models.PlanoContas>
@{
    ViewData["Title"] = "Plano de contas";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Plano de contas</h1>
        <p class="text-secondary mb-0">Classifique receitas, despesas e custos da empresa ativa.</p>
    </div>
    <a href="/PlanoContas/Criar" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nova conta
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
        <div class="input-group" style="max-width:480px">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input id="accountSearch" type="search" class="form-control" placeholder="Buscar por código ou descrição" autocomplete="off" />
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Código</th>
                    <th>Descrição</th>
                    <th>Tipo</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody id="accountsTable">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-secondary py-5">Nenhuma conta cadastrada.</td></tr>
                }
                @foreach (var conta in Model)
                {
                    <tr data-account-row>
                        <td class="fw-semibold" data-search-value>@conta.CodigoClassificacao</td>
                        <td data-search-value>@conta.Descricao</td>
                        <td>
                            @if (conta.Tipo == "R")
                            {
                                <span class="badge bg-success">Receita</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Despesa</span>
                            }
                        </td>
                        <td class="text-end">
                            <a href="/PlanoContas/Editar/@conta.PlanoContasId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <form action="/PlanoContas/Excluir/@conta.PlanoContasId" method="post" class="d-inline" onsubmit="return confirm('Excluir esta conta?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Excluir
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('accountSearch').addEventListener('input', event => {
            const term = event.target.value.trim().toLocaleLowerCase('pt-BR');
            document.querySelectorAll('[data-account-row]').forEach(row => {
                const content = [...row.querySelectorAll('[data-search-value]')]
                    .map(cell => cell.textContent)
                    .join(' ')
                    .toLocaleLowerCase('pt-BR');
                row.hidden = term !== '' && !content.includes(term);
            });
        });
    </script>
}
